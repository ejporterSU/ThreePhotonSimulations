   "source": [
    "x1 = [np.sum(ims[i,bins[1]:bins[2],:])/np.sum(ims[i,bins[1]:bins[3],:]) for i in range(len(ims))]\n",
    "x2 = [np.sum(ims[i,bins[2]:bins[3],:])/np.sum(ims[i,bins[1]:bins[3],:]) for i in range(len(ims))]\n",
    "\n",
    "nrepeats=5\n",
    "npoints=len(exp.x)*nrepeats\n",
